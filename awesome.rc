# awesome.rc — fleet manifest for make-awesome.py --fleet
# One section per managed app.
#
# Fields:
#   path        = local dev directory (required)
#   type        = hook | script | wrapper | ui | core
#   timing      = yes | no        — eligible for --timing injection
#   debug       = yes | no        — eligible for --debug injection
#   skip        = yes             — exclude from all fleet ops (omit or no to include)
#   status      = release | testing | wip | suspended | archived
#   envar_ready = yes | no        — updated for TW_TASK_DIR/TASKRC isolation (B+C)

[recurrence-overhaul]
path        = ~/dev/tw-recurrence_overhaul-hook
type        = hook
timing      = yes
debug       = yes
status      = release
envar_ready = yes

[timelog]
path        = ~/dev/tw-timelog-hook
type        = hook
timing      = yes
debug       = yes
status      = release
envar_ready = no

[subtask]
path        = ~/dev/tw-subtask-hook
type        = hook
timing      = yes
debug       = yes
status      = release
envar_ready = yes

[need-priority]
path        = ~/dev/tw-need_priority-hook
type        = hook
timing      = yes
debug       = yes
status      = release
envar_ready = yes

[agenda-edate]
path        = ~/dev/tw-agenda-hook
