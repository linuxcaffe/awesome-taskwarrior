# awesome.rc — fleet manifest for make-awesome.py --fleet
# One section per managed app.
#
# Fields:
#   path        = local dev directory (required)
#   type        = hook | script | wrapper | ui | core
#   timing      = yes | no        — eligible for --timing injection
#   debug       = yes | no        — eligible for --debug injection
#   skip        = yes             — exclude from all fleet ops (omit or no to include)
#   status      = release | testing | wip | suspended | archived
#   envar_ready  = yes | no       — updated for TW_TASK_DIR/TASKRC isolation (B+C)
#   skip_testing = yes            — exempt from --fleet --testing gate (app has no tests yet)
#   tw_web      = yes | no | partial
#                 yes     — fully compatible with tw-web (non-interactive)
#                 no      — requires terminal interaction; must guard with TW_WEB=1 check
#                 partial — won't hang but some features don't work (e.g. desktop notify)
#                 tw-web sets TW_WEB=1 in every subprocess; hooks should check and skip
#                 interactive parts (input(), /dev/tty, fzf, whiptail, hledger-add, etc.)

[recurrence-overhaul]
path        = ~/dev/tw-recurrence_overhaul-hook
type        = hook
timing      = yes
debug       = yes
status      = release
envar_ready = yes
tw_web      = yes

[timelog]
path        = ~/dev/tw-timelog-hook
type        = hook
timing      = yes
debug       = yes
status      = release
envar_ready = no
tw_web      = yes      # writes to timeclock file; not interactive

[subtask]
path        = ~/dev/tw-subtask-hook
type        = hook
timing      = yes
debug       = yes
status      = release
envar_ready = yes
tw_web      = no       # opens /dev/tty for single-char prompts; needs TW_WEB guard

[need-priority]
path        = ~/dev/tw-need_priority-hook
type        = hook
timing      = yes
debug       = yes
status      = release
envar_ready = yes
tw_web      = yes

[agenda-edate]
path        = ~/dev/tw-agenda-hook
type        = hook
timing      = yes
debug       = yes
status      = release
envar_ready = no
tw_web      = yes

[smart-nag]
path        = ~/dev/tw-smart-nag-hook
type        = hook
timing      = yes
debug       = yes
status      = release
envar_ready = no
tw_web      = partial  # nag message won't reach web user; won't hang

[wikitags]
path        = ~/dev/tw-wikitags-hook
type        = hook
timing      = yes
debug       = yes
status      = wip
envar_ready = no
tw_web      = yes

[hledger-add]
